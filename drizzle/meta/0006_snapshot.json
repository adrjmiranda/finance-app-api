    "public.transactions_balance_view": {
      "columns": {
        "user_id": {
          "name": "user_id",
          "type": "uuid",
          "primaryKey": false,
          "notNull": false
        },
        "earnings": {
          "name": "earnings",
          "type": "numeric",
          "primaryKey": false,
          "notNull": false
        },
        "expenses": {
          "name": "expenses",
          "type": "numeric",
          "primaryKey": false,
          "notNull": false
        },
        "investiments": {
          "name": "investiments",
          "type": "numeric",
          "primaryKey": false,
          "notNull": false
        },
        "balances": {
          "name": "balances",
          "type": "numeric",
          "primaryKey": false,
          "notNull": false
        }
      },
      "definition": "\n    SELECT \n      \"transactions\".\"user_id\" as user_id,\n      SUM(CASE WHEN \"transactions\".\"type\" = 'earning' THEN \"transactions\".\"amount\" ELSE 0 END) as earnings,\n      SUM(CASE WHEN \"transactions\".\"type\" = 'expense' THEN \"transactions\".\"amount\" ELSE 0 END) as expenses,\n      SUM(CASE WHEN \"transactions\".\"type\" = 'investment' THEN \"transactions\".\"amount\" ELSE 0 END) as investiments,\n      SUM(CASE WHEN \"transactions\".\"type\" = 'earning' THEN \"transactions\".\"amount\" ELSE -\"transactions\".\"amount\" END) as balances\n    FROM \"transactions\"\n    GROUP BY \"transactions\".\"user_id\"\n  ",
      "name": "transactions_balance_view",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
  },
